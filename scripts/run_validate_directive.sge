#!/bin/bash
#$ -S /bin/bash
#$ -N combhts_validate_directive
#$ -j y
#$ -pe smp 4
#$ -l h_rt=12:00:00
#$ -o /home/shic4/combhts_validate_directive.o$JOB_ID

# Full directive section-7 validation package. Real xTB work must run through SGE.
set -uo pipefail

if [ -f /etc/profile.d/modules.sh ]; then
    source /etc/profile.d/modules.sh
fi
module load anaconda/3-2023.09
module load xtb/6.4.1

source "$(conda info --base)/etc/profile.d/conda.sh"
conda activate combhts

cd "${COMBHTS_ROOT:-$HOME/CombHTS_section7}"
export PYTHONPATH="$PWD/src${PYTHONPATH:+:$PYTHONPATH}"
export OMP_NUM_THREADS="${NSLOTS:-4}"
export OMP_STACKSIZE=4G
ulimit -s unlimited || true

VALIDATE_HARVEST="${VALIDATE_HARVEST:-$PWD/outputs/tier1_real_7488_salt_fixed/tier1_all.csv}"
VALIDATE_OUTDIR="${VALIDATE_OUTDIR:-$PWD/outputs/directive_section7_validation}"
VALIDATE_CACHE="${VALIDATE_CACHE:-$VALIDATE_OUTDIR/cache.sqlite}"

python -m eps.cli validate-directive \
    --engine xtb \
    --harvest "$VALIDATE_HARVEST" \
    --cache "$VALIDATE_CACHE" \
    --outdir "$VALIDATE_OUTDIR"
